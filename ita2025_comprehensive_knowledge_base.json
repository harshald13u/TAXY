  "residence_rules": {
    "individual": {
      "section": "6(2)",
      "primary_test": ">= 182 days in India in tax year",
      "secondary_test": ">= 60 days in tax year AND >= 365 days in 4 preceding tax years",
      "exceptions": [
        "60-day rule waived for Indian citizens leaving for employment / Indian-ship crew",
        "60-day extends to 120 days for Indian citizens/PIO visiting with Indian-source income > 15 lakh"
      ],
      "deemed_resident": {
        "section": "6(7)",
        "trigger": "Indian citizen + not liable to tax in any other country + Indian-source income > 15 lakh"
      }
    },
    "not_ordinarily_resident": {
      "section": "6(13)",
      "tests": [
        "Non-resident in 9 of 10 preceding years",
        "<= 729 days in 7 preceding years",
        "Indian citizen/PIO with > 15 lakh income + 120-181 days",
        "Deemed resident under 6(7)"
      ]
    },
    "huf_firm_aop": {
      "section": "6(9)",
      "test": "Resident UNLESS control & management wholly outside India"
    },
    "company": {
      "section": "6(10)",
      "test": "Indian company OR POEM in India"
    },
    "single_residence_rule": {
      "section": "6(12)",
      "rule": "If resident for one source, deemed resident for ALL sources"
    }
  },
  "scope_of_total_income": {
    "section": "5",
    "resident": "ALL income (received in India + accruing in India + accruing outside India)",
    "nor": "Indian-source + foreign income from India-controlled business / India-set-up profession ONLY",
    "non_resident": "Indian-source ONLY (received or accruing in India)"
  },
