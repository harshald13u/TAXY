        "PART A",
        "TRACES",
        "Certificate under Section 203",
        "Quarterly Statement",
        "Acknowledgement Number",
        "Last updated on",
        "Receipt Numbers of original quarterly statements"
      ],
      "extracts": ["employer", "pan", "tan", "tdsPaid"],
      "primary_fields": ["tdsPaid", "pan", "tan"]
    },

