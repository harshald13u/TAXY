  "field_definitions": {

    "pan": {
      "regex": "\\b([A-Z]{5}[0-9]{4}[A-Z])\\b",
      "validation": "5 letters + 4 digits + 1 letter; 4th letter encodes type (P/F/C/H/A/T/B/L/J/G)",
      "example": "ABCDE1234F",
      "min_length": 10,
      "max_length": 10,
      "section_ref": "Sec 139A"
    },

    "aadhaar": {
      "regex": "\\b([0-9]{4}\\s?[0-9]{4}\\s?[0-9]{4})\\b",
      "validation": "12 digits, often shown with spaces every 4",
      "example": "1234 5678 9012",
      "warning": "PII — never log full value"
    },

    "ifsc": {
      "regex": "\\b([A-Z]{4}0[A-Z0-9]{6})\\b",
      "validation": "4 letters + 0 + 6 alphanumeric",
      "example": "HDFC0000123"
    },

    "tan": {
      "regex": "\\b([A-Z]{4}[0-9]{5}[A-Z])\\b",
      "validation": "4 letters + 5 digits + 1 letter",
      "example": "DELS01234F"
    },

    "salary": {
      "labels_strong": [
        "gross salary", "gross pay", "gross earnings", "gross income",
        "total salary", "total earnings", "total pay",
        "annual salary", "annual income", "annual ctc", "annual pay",
        "total ctc", "cost to company",
        "salary credited", "net pay annual",
        "income from salary"
      ],
      "labels_weak": [
        "basic salary", "basic pay", "basic+da", "basic and da",
        "fixed cash", "total fixed pay", "fixed pay",
        "salary"
      ],
      "min_value": 100000,
      "max_value": 100000000,
      "section_ref": "Sec 15-19",
      "notes": "Strong labels imply gross; weak labels need component-summing fallback"
    },

    "hra": {
