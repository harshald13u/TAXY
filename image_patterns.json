{
  "_meta": {
    "version": "1.0",
    "purpose": "Comprehensive pattern library for parsing tax-related documents from images/PDFs. Used by parseAnyTaxDocument() in app.html.",
    "last_updated": "2026-05-04",
    "design": "Each document_type has detection_signals (to identify the document) and field_extractors (to pull the values). Field aliases are exhaustive — every label variation we've seen across employers, banks, brokers."
  },

  "document_types": {

    "form16_part_b": {
      "label": "Form 16 — Part B (TDS Salary Certificate)",
      "issued_by": "Employer",
      "frequency": "Annual",
      "detection_signals": [
        "FORM NO. 16",
        "FORM NO 16",
        "Annexure - II",
        "Part B (Annexure)",
        "PART B",
        "Salary as per provisions",
        "Section 17(1)",
        "Section 17(2)",
        "TAN of the Deductor",
        "Certificate under section 203"
      ],
      "extracts": ["employer", "pan", "salary", "hra", "lta", "perquisites", "profits_in_lieu", "sec80c", "sec80d", "sec80g", "sec80ccd", "tdsPaid", "standard_deduction", "professional_tax"],
      "primary_fields": ["salary", "tdsPaid", "pan"],
      "section_ref": "Sec 392 (old 192) — Salary TDS certificate"
    },

    "form16_part_a": {
      "label": "Form 16 — Part A (TDS-only summary)",
      "issued_by": "TRACES (auto-generated)",
